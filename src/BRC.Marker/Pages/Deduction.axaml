<UserControl
x:Class="BRC.Marker.Pages.Deduction"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:local="clr-namespace:BRC.Marker.Pages"
d:DesignHeight="450"
d:DesignWidth="800"
mc:Ignorable="d">
	<Grid
	HorizontalAlignment="Stretch"
	VerticalAlignment="Stretch"
	ColumnDefinitions="1*, Auto, 3*"
	DragDrop.AllowDrop="True"
	DragDrop.Drop="OnDrop">

		<Border
		Grid.Column="0"
		HorizontalAlignment="Stretch"
		Background="{DynamicResource SemiGrey0Color}"
		CornerRadius="10" >
			<StackPanel Spacing="10" Margin="10">

				<Button Click="ButtonClick_ChooseModel" Content="选择推理模型" HorizontalAlignment="Stretch" />
				<Button Click="ButtonClick_ChooseFile" Content="选择推理数据" HorizontalAlignment="Stretch" />
				<Button Click="ButtonClick_ChooseExe" Content="选择推理程序" HorizontalAlignment="Stretch" />

				<Button Click="ButtonClick_output" Content="推理后图片存放地址" HorizontalAlignment="Stretch" />
				

				<Grid ColumnDefinitions="Auto, *" Margin="4,0,0,5">
					<TextBlock Text="置信度 (0.1 - 0.9):" VerticalAlignment="Center" Margin="0,0,10,0"/>
					<NumericUpDown x:Name="InputConfidence" Grid.Column="1" Value="0.7" Minimum="0.1" Maximum="0.9" Increment="0.1"/>
				</Grid>

				<Separator Background="Gray" Height="1" Margin="0,10" />

				<Button Click="ButtonClick_StartDeduction" Content="开始推理" HorizontalAlignment="Stretch" Classes="Tertiary" />
				<TextBlock x:Name="DeductionModelName" Text="被选中的模型名：" TextWrapping="Wrap" Margin="4,12,4,0" />
				<TextBlock x:Name="ChooseExeName" Text="被选中的推理程序名：" TextWrapping="Wrap" Margin="4,12,4,0" />
				<TextBlock x:Name="OutputPathText" Text="未选择存放地址：" TextWrapping="Wrap" Margin="4,12,4,0"/>
			</StackPanel>
		</Border>

		<GridSplitter Grid.Column="1" ShowsPreview="True" />

		<Border
		Grid.Column="2"
		HorizontalAlignment="Stretch"
		VerticalAlignment="Stretch"
		Background="{DynamicResource SemiGrey0Color}"
		CornerRadius="10" >

			<Grid RowDefinitions="Auto, *" Margin="10">
				<TextBlock Grid.Row="0"
						   Text="推理数据略缩图"
						   FontWeight="Bold"
						   HorizontalAlignment="Center"
						   Margin="0,0,0,10"/>

				<ListBox Grid.Row="1"
						 x:Name="TrainDataListBox"
						 Background="Transparent"
						 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

					<ListBox.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal" />
						</ItemsPanelTemplate>
					</ListBox.ItemsPanel>

					<ListBox.ItemTemplate>
						<DataTemplate DataType="local:DeductionImageItem">
							<Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="5" Margin="5" Background="White">
								<StackPanel Width="120">
									<Image Source="{Binding Thumbnail}"
										   Height="100"
										   Stretch="Uniform"
										   Margin="0,0,0,5"/>
									<TextBlock Text="{Binding FileName}"
											   HorizontalAlignment="Center"
											   TextTrimming="CharacterEllipsis"
											   ToolTip.Tip="{Binding FileName}"/>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>

				</ListBox>
			</Grid>
		</Border>
</Grid>
</UserControl>
